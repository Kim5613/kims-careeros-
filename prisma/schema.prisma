// HR 个人职业中台 - 数据库模型

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================================
// 基础数据层（中台核心）- 所有模块共享
// ========================================

model Company {
  id          String   @id @default(cuid())
  name        String
  industry    String?
  scale       String?
  city        String?
  website     String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 关联
  applications    JobApplication[]
  candidates      Candidate[]
  promotions      Promotion[]
  salaryChanges   SalaryChange[]
  contactLinks    ContactCompany[]
  positionKnowledge PositionKnowledge[]

  @@map("companies")
}

model Contact {
  id                  String   @id @default(cuid())
  name                String
  relationType        String   // 猎头/HR同行/前同事/面试官/用人部门/候选人
  phone               String?
  email               String?
  wechat              String?
  tags                String[]               // 自定义标签：行业/职能/靠谱度/内推意愿等
  lastInteractionDate DateTime?              // 上次互动时间
  interactionFrequency String?               // 建议联系频率：monthly/quarterly/halfYearly
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  companies           ContactCompany[]
  interactions        InteractionRecord[]

  @@map("contacts")
}

model InteractionRecord {
  id          String   @id @default(cuid())
  contactId   String
  date        DateTime @default(now())
  content     String                   // 一句话记录聊了什么
  createdAt   DateTime @default(now())

  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@map("interaction_records")
}

model ContactCompany {
  id        String  @id @default(cuid())
  contactId String
  companyId String

  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([contactId, companyId])
  @@map("contact_companies")
}

model Tag {
  id       String  @id @default(cuid())
  name     String  @unique
  category String? // skill/industry/knowledge/status

  @@map("tags")
}

// ========================================
// 模块一：我的求职管理
// ========================================

model JobApplication {
  id             String   @id @default(cuid())
  companyId      String
  positionName   String
  industry       String?  // 行业
  salaryMin      Int?
  salaryMax      Int?
  offerSalary    Int?
  currentStage   String   @default("未投递") // 未投递/已投递/面试/offer/已入职/已结束
  stageDetail    String?                     // 二级：已沟通/一面/二面/三面/终面/已谈薪/接offer/拒offer
  source         String?                     // 招聘网站/猎头/内推/官网
  location       String?                     // base地（城市）
  appliedDate    DateTime?
  jdLink         String?                     // JD 链接
  jdText         String?  @db.Text           // JD 原文/描述
  resumeVersion  String?                     // 关联简历版本
  endReason      String?                     // 结束原因：简历挂/面试挂/ghost/自己放弃/已入职
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company        Company              @relation(fields: [companyId], references: [id])
  interviews     InterviewRecord[]
  negotiations   SalaryNegotiation[]

  @@map("job_applications")
}

model InterviewRecord {
  id              String   @id @default(cuid())
  applicationId   String
  interviewDate   DateTime
  interviewType   String   @default("现场")  // 电话/视频/现场
  interviewer     String?
  position        String?                   // 面试岗位
  title           String?                   // 面试官 title
  content         String?                   // 沟通内容
  result          String?                   // 面试结果
  notes           String?
  reviewNotes     String?  @db.Text         // 复盘笔记：面试官风格/关键问题/回答反思/团队判断
  createdAt       DateTime @default(now())

  application     JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("interview_records")
}

model SalaryNegotiation {
  id              String   @id @default(cuid())
  applicationId   String
  expectedSalary  Int?
  offeredSalary   Int?
  finalSalary     Int?
  leverage        String?  // 谈判筹码
  strategy        String?  // 使用策略
  outcome         String?  // 结果
  notes           String?  // 复盘
  createdAt       DateTime @default(now())

  application     JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("salary_negotiations")
}

// ========================================
// 模块二：我的薪酬与晋升
// ========================================

model Promotion {
  id              String   @id @default(cuid())
  date            DateTime
  previousLevel   String?
  newLevel        String?
  companyId       String
  reason          String?
  summary         String?
  createdAt       DateTime @default(now())

  company         Company @relation(fields: [companyId], references: [id])

  @@map("promotions")
}

model SalaryChange {
  id              String   @id @default(cuid())
  date            DateTime
  amount          Int
  changeType      String   // 晋升调薪/年度调薪/跳槽/其他
  companyId       String
  notes           String?
  createdAt       DateTime @default(now())

  company         Company @relation(fields: [companyId], references: [id])

  @@map("salary_changes")
}

model Milestone {
  id              String   @id @default(cuid())
  date            DateTime
  title           String
  description     String?
  tags            String[]
  createdAt       DateTime @default(now())

  @@map("milestones")
}

model Achievement {
  id              String   @id @default(cuid())
  title           String
  description     String?
  date            DateTime
  project         String?
  impact          String?
  createdAt       DateTime @default(now())

  @@map("achievements")
}

model AnnualReview {
  id              String   @id @default(cuid())
  year            Int      @unique
  highlights      String?
  improvements    String?
  goals           String?
  nextYearPlan    String?
  createdAt       DateTime @default(now())

  @@map("annual_reviews")
}

model GoalOKR {
  id              String   @id @default(cuid())
  objective       String
  keyResults      String?
  status          String   @default("进行中") // 进行中/已完成/已放弃
  startDate       DateTime?
  endDate         DateTime?
  progress        Int      @default(0) // 百分比
  createdAt       DateTime @default(now())

  @@map("goal_okrs")
}

// ========================================
// 模块三：我的简历与求职信
// ========================================

model Resume {
  id              String   @id @default(cuid())
  title           String
  content         String   @db.Text
  targetPosition  String?
  targetCompany   String?
  version         Int      @default(1)
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  attachments     Attachment[]
  coverLetters    CoverLetter[]

  @@map("resumes")
}

model CoverLetter {
  id              String   @id @default(cuid())
  title           String
  content         String
  targetCompany   String?
  targetPosition  String?
  resumeId        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  resume          Resume?  @relation(fields: [resumeId], references: [id], onDelete: SetNull)

  @@map("cover_letters")
}

model SelfIntroduction {
  id              String   @id @default(cuid())
  title           String
  content         String
  scenario        String   // 面试/电话/社交场合
  duration        String?  // 30秒/1分钟/3分钟
  tags            String[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("self_introductions")
}

// ========================================
// HR工作台：候选人简历库
// ========================================

model Candidate {
  id              String   @id @default(cuid())
  name            String
  phone           String?
  email           String?
  companyId       String?
  position        String?
  skills          String[]
  experienceYears Int?
  source          String?  // 来源渠道
  resumeSnapshot  String?  // 简历快照（Markdown或JSON）
  status          String   @default("待筛选") // 待筛选/面试中/已录用/已拒绝/暂缓/放弃
  offerSalary     Int?
  followUpStatus  String?
  talentPoolTag   Boolean  @default(false) // 是否标记为人才储备
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company         Company? @relation(fields: [companyId], references: [id])
  interviews      CandidateInterview[]
  attachments     Attachment[]

  @@map("candidates")
}

model CandidateInterview {
  id              String   @id @default(cuid())
  candidateId     String
  round           Int
  interviewDate   DateTime
  interviewer     String?
  evaluation      String?
  notes           String?
  createdAt       DateTime @default(now())

  candidate       Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("candidate_interviews")
}

// ========================================
// HR工作台：招聘知识库
// ========================================

model PositionKnowledge {
  id              String   @id @default(cuid())
  companyId       String?
  positionCategory String  // 岗位分类：算法/产品/财务/销售/技术/运营等
  terminology     String?  // 技术术语 & 业务背景
  jdTemplate      String?  // JD 模板
  evaluationCriteria String? // 评估标准
  salaryRangeMin  Int?
  salaryRangeMax  Int?
  marketInfo      String?  // 市场行情参考
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company         Company? @relation(fields: [companyId], references: [id])

  @@map("position_knowledge")
}

// ========================================
// HR工作台：市场洞察
// ========================================

model MarketInsight {
  id              String   @id @default(cuid())
  title           String
  content         String
  category        String   // 薪酬对标/人才趋势/行业动态
  industry        String?
  position        String?
  dataPoints      String?  // JSON 格式的数据点
  source          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("market_insights")
}

// ========================================
// 文件附件 - 简历/候选人文件上传
// ========================================

model Attachment {
  id          String    @id @default(cuid())
  filename    String               // 原始文件名，如 "张三简历.pdf"
  storedPath  String               // 存储路径，如 "candidates/abc123/uuid.pdf"
  mimeType    String               // 如 "application/pdf"
  size        Int                  // 文件大小（字节）
  entityType  String               // "resume" 或 "candidate"
  resumeId    String?
  candidateId String?
  parsedText  String?  @db.Text    // 解析出的文本内容
  createdAt   DateTime @default(now())

  resume       Resume?   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  candidate    Candidate? @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([entityType, resumeId])
  @@index([entityType, candidateId])
  @@map("attachments")
}

// ========================================
// 待办事项
// ========================================

model Todo {
  id          String   @id @default(cuid())
  date        String                   // YYYY-MM-DD
  title       String                   // 标题
  time        String?                  // HH:mm 开始时间
  endTime     String?                  // HH:mm 结束时间
  color       String   @default("#1677ff")  // 背景色
  location    String?                  // 地点
  description String?                  // 描述
  reminder    String?                  // 15min / 30min / 1hour
  repeat      String?                  // none / daily / weekly / monthly
  category    String?                  // work | personal | null
  isTodo      Boolean  @default(true)  // 是否同步到待办面板
  mustAttend  Boolean  @default(false) // 是否必须本人参加
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([date])
  @@map("todos")
}

// 电影台词库
model MovieQuote {
  id          String    @id @default(cuid())
  quote       String
  translation String?                   // 中文翻译（原句非中文时）
  movie       String
  used        Boolean   @default(false)
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  @@map("movie_quotes")
}

// 本周重点便签
model WeeklyFocus {
  id              String   @id @default(cuid())
  weekStart       String   @unique               // 周一日期 YYYY-MM-DD
  workContent     String   @default("") @db.Text
  personalContent String   @default("") @db.Text
  updatedAt       DateTime @updatedAt

  @@map("weekly_focus")
}

// AI 桌宠记忆 — 芝士的长期记忆库
model PetMemory {
  id        String   @id @default(cuid())
  type      String   // fact | preference | event | decision
  content   String   @db.Text  // 记忆内容（一句中文摘要）
  keywords  String[] // 搜索关键词
  source    String?  // 来自哪次对话（trace）
  version   Int      @default(1) // Source→Concept→Synthesis 提炼层次
  mergedFrom String[] @default([]) // 合并来源（version>=2时指向原始记忆 ID）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([version])
  @@map("pet_memory")
}
