# 数据库连接（请修改为你的实际数据库信息）
DATABASE_URL="postgresql://hr_user:your_password@localhost:5432/hr_platform"

# Prisma 引擎国内镜像（国内环境必须配置）
PRISMA_ENGINES_MIRROR="https://cdn.npmmirror.com/binaries/prisma"

# AI (DeepSeek) — 大师智囊团/岗位诊断/桌宠对话都依赖它，缺失时接口会返回 200 空响应
DEEPSEEK_API_KEY="sk-xxx"

# 登录态 JWT 签名密钥（生产环境必须设置为随机长字符串）
JWT_SECRET="change-me-to-a-long-random-string"

# 联网搜索（可选但强烈推荐）：DuckDuckGo 在国内服务器基本不可用，
# 配了 TAVILY_API_KEY 才走 Tavily；免费额度 1000 次/月，https://tavily.com
TAVILY_API_KEY="tvly-xxx"

# 桌宠接口令牌（强烈推荐）：/api/chat 无需登录即可访问（桌宠无登录态），
# 配了之后客户端必须带 x-pet-token 头，防止陌生人刷 DeepSeek 额度
PET_TOKEN="change-me-to-a-random-string"
